<div id="<%= dom_id guest %>">
  <div>
    <strong>Room:</strong>
    <%= guest.room %>
  </div>

  <div>
    <strong>First name:</strong>
    <%= guest.first_name %>
  </div>

  <div>
    <strong>Last name:</strong>
    <%= guest.last_name %>
  </div>

  <div>
    <strong>Phone:</strong>
    <%= guest.phone %>
  </div>

  <div>
    <strong>Email:</strong>
    <%= guest.email %>
  </div>

</div>
