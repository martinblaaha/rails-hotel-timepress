<div id="<%= dom_id room %>">
  <div>
    <strong>Room number:</strong>
    <%= room.room_number %>
  </div>

  <div>
    <strong>Room ID:</strong>
    <%= room.id %>
  </div>

  <div>
    <strong>Bed count:</strong>
    <%= room.bed_count %>
  </div>

  <div>
    <strong>Available:</strong>
    <%= room.is_free ? "Yes" : "No"%>
  </div>

</div>
